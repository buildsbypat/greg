[Unit]
Description=Greg Da Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=gregbot
Group=gregbot
WorkingDirectory=/opt/greg/app
EnvironmentFile=/opt/greg/app/.env
ExecStart=/opt/greg/app/.venv/bin/python /opt/greg/app/main.py
Restart=always
RestartSec=5

NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/opt/greg/data

[Install]
WantedBy=multi-user.target